{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgresCacheConnection": "Host=localhost;Database=product_cache_db;Username=postgres;Password=postgres;"
  },
  "AllowedHosts": "*",
  "AmazonURL": {
    "SearchURL": "https://www.Amazon.com/s?ref=nb_sb_noss&k=",
    "ProductDetailsURL": "https://www.amazon.com/ref=sr_1_1/dp/",
    "ProductOffersURL": "https://www.amazon.com/gp/offer-listing/"
  },
  "AmazonSelectors": {
    "DataComponent": "//*[@data-component-type='s-search-result']",
    "ASIN": [ "//th[contains(text(),'ASIN')]/following-sibling::td" ],
    "Title": [
      ".//h2//span",
      "//*[@id='productTitle']"
    ],
    "Price": [
      "//span[@class='a-price aok-align-center']//span[@class='a-offscreen']",
      "//span[@id='priceblock_ourprice']",
      "//span[@class='a-price']//span[@class='a-offscreen']"
    ],
    "Rating": [
      ".//*[contains(@class,'a-icon-alt')]"
    ],
    "ReviewCount": [
      "//span[@id='acrPopover']//span[@class='a-icon-alt']",
      "//div[@data-csa-c-slot-id='alf-reviews']"
    ],
    "ProductURL": [
      ".//span/a"
    ],
    "MainProductImageURL": [
      ".//img"
    ],
    "IsPrime": [
      "//*[contains(@class, 'a-icon-prime')]",
      "//*[contains(@aria-label, 'Amazon Prime')]"
    ],
    "FeatureBullets": [ "//*[@id='feature-bullets']//li" ],
    "AllProductImages": [ "//img[contains(@class,'a-dynamic-image')]" ],
    "ProductSpecifications": [ "//*[@id='productDetails_detailBullets_sections1']//tr" ],
    "Variants": [ "//*[@id='feature-bullets']//li" ],
    "Categories": [ "//*[@id='wayfinding-breadcrumbs_feature_div']//li//a" ],
    "brand": [
      "//*[@id='bylineInfo']",
      "//*[@id='brand']",
      "//tr[th[contains(.,'Brand')]]/td",
      "//li[contains(.,'Brand')]/span[last()]"
    ],
    "Availability": [ "//*[@id='availability']//span" ],
    "Description": [ "//*[@id='productDescription']" ]
  }
}
